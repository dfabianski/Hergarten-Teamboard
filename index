<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT- & Digitalisierungs-Pipeline</title>
    <!-- Tailwind CSS für ein modernes, ansprechendes Enterprise-Design -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons für professionelle Symbole -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Schöne Scrollbars für ein sauberes UI */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen pb-12">

    <!-- Header-Bereich -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40 px-6 py-4 shadow-sm">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <div class="flex items-center gap-2">
                    <div class="p-2 bg-blue-600 rounded-lg text-white">
                        <i data-lucide="kanban-square" class="w-6 h-6"></i>
                    </div>
                    <h1 class="text-2xl font-bold text-slate-950 tracking-tight">IT- & Digitalisierungs-Pipeline</h1>
                </div>
                <p class="text-sm text-slate-500 mt-1">Zentrales Projektmanagement mit Echtzeit-Cloud-Synchronisation</p>
            </div>
            
            <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                <!-- Suchleiste -->
                <div class="relative w-full sm:w-64">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </span>
                    <input type="text" id="suche" placeholder="Projekt suchen..." 
                           class="w-full pl-10 pr-4 py-2 bg-slate-100 focus:bg-white border border-transparent focus:border-blue-500 rounded-lg text-sm transition-all outline-none"
                           oninput="filterProjekte()">
                </div>
                <!-- Aktivitätsverlauf Toggle Button -->
                <button onclick="toggleVerlauf()" class="relative w-full sm:w-auto bg-white hover:bg-slate-50 text-slate-700 font-semibold py-2 px-4 rounded-lg text-sm border border-slate-200 shadow-sm flex items-center justify-center gap-2 transition-all">
                    <i data-lucide="history" class="w-4 h-4 text-slate-500"></i>
                    <span>Verlauf</span>
                    <span class="absolute -top-1 -right-1 w-2.5 h-2.5 bg-blue-600 rounded-full hidden" id="verlaufBadge"></span>
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 mt-8">
        
        <!-- Dashboard / Schnellstatistik -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center gap-3">
                <div class="p-3 bg-slate-100 rounded-lg text-slate-600"><i data-lucide="layers" class="w-5 h-5"></i></div>
                <div>
                    <div class="text-2xl font-bold" id="stat-gesamt">0</div>
                    <div class="text-xs text-slate-500 font-medium">Projekte gesamt</div>
                </div>
            </div>
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center gap-3">
                <div class="p-3 bg-blue-50 rounded-lg text-blue-600"><i data-lucide="git-pull-request" class="w-5 h-5"></i></div>
                <div>
                    <div class="text-2xl font-bold text-blue-600" id="stat-arbeit">0</div>
                    <div class="text-xs text-slate-500 font-medium font-medium">In Umsetzung</div>
                </div>
            </div>
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center gap-3">
                <div class="p-3 bg-amber-50 rounded-lg text-amber-600"><i data-lucide="flask-conical" class="w-5 h-5"></i></div>
                <div>
                    <div class="text-2xl font-bold text-amber-600" id="stat-test">0</div>
                    <div class="text-xs text-slate-500 font-medium font-medium">Im Test</div>
                </div>
            </div>
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center gap-3">
                <div class="p-3 bg-emerald-50 rounded-lg text-emerald-600"><i data-lucide="check-circle2" class="w-5 h-5"></i></div>
                <div>
                    <div class="text-2xl font-bold text-emerald-600" id="stat-fertig">0</div>
                    <div class="text-xs text-slate-500 font-medium font-medium">Erfolgreich beendet</div>
                </div>
            </div>
        </div>

        <!-- Formular zum Erstellen / Bearbeiten -->
        <section class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 mb-8 form-container">
            <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                <div class="flex items-center gap-2">
                    <i data-lucide="plus-circle" class="w-5 h-5 text-blue-600"></i>
                    <h2 class="text-lg font-bold text-slate-900" id="formularTitel">Neues IT-Projekt erfassen</h2>
                </div>
                <button id="btnAbbrechen" onclick="setzeFormularZurueck()" class="text-xs text-slate-500 hover:text-slate-800 hidden flex items-center gap-1">
                    <i data-lucide="x" class="w-3.5 h-3.5"></i> Abbrechen
                </button>
            </div>
            
            <form id="projektForm">
                <input type="hidden" id="editId">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                    <!-- Reihe 1 -->
                    <div class="md:col-span-4">
                        <label for="titel" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">Projektname</label>
                        <input type="text" id="titel" placeholder="z.B. Cloud-Migration" required 
                               class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div class="md:col-span-8">
                        <label for="beschreibung" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">Beschreibung</label>
                        <input type="text" id="beschreibung" placeholder="Kurze Beschreibung des Ziels..." required 
                               class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>

                    <!-- Reihe 2 -->
                    <div class="md:col-span-3">
                        <label for="mitarbeiter" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">Verantwortlich (Mitarbeiter)</label>
                        <input type="text" id="mitarbeiter" placeholder="z.B. Max Mustermann" required 
                               class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div class="md:col-span-3">
                        <label for="deadline" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">Fälligkeitsdatum (Deadline)</label>
                        <input type="date" id="deadline" required 
                               class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label for="kategorie" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">Kategorie</label>
                        <select id="kategorie" class="w-full px-3 py-2 border border-slate-200 rounded-lg bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                            <option value="Digital">Digital</option>
                            <option value="Infrastruktur">Infrastruktur</option>
                            <option value="Organisation">Organisation</option>
                            <option value="Schnittstelle">Schnittstelle</option>
                            <option value="Event">Event</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label for="prio" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">Priorität</label>
                        <select id="prio" class="w-full px-3 py-2 border border-slate-200 rounded-lg bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                            <option value="prio-niedrig">Niedrig (Grün)</option>
                            <option value="prio-mittel" selected>Mittel (Gelb)</option>
                            <option value="prio-hoch">Hoch (Rot)</option>
                        </select>
                    </div>
                    <div class="md:col-span-2 flex items-end">
                        <button type="submit" id="btnSpeichern" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg text-sm shadow-sm transition-all flex items-center justify-center gap-1.5 h-[38px]">
                            <i data-lucide="check" class="w-4 h-4"></i>
                            <span id="btnText">Anlegen</span>
                        </button>
                    </div>
                </div>
            </form>
        </section>

        <!-- Kanban Board Layout -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-start">
            
            <!-- Spalte: Neu -->
            <div class="bg-slate-100 rounded-xl p-4 border border-slate-200 shadow-sm transition-all duration-200 column-container" id="col-neu">
                <div class="flex items-center justify-between border-b-2 border-slate-400 pb-2 mb-4">
                    <span class="font-bold text-slate-700 flex items-center gap-1.5 text-sm uppercase tracking-wide">
                        <span class="w-2.5 h-2.5 rounded-full bg-slate-500"></span> Neu
                    </span>
                    <span class="bg-slate-200 text-slate-700 text-xs font-bold px-2 py-0.5 rounded-full" id="zaehler-neu">0</span>
                </div>
                <!-- Drop-Zone -->
                <div class="karten-liste space-y-3 min-h-[400px] transition-all rounded-lg" id="liste-neu"
                     ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)" ondrop="drop(event, 'neu')">
                </div>
            </div>

            <!-- Spalte: In Arbeit -->
            <div class="bg-slate-100 rounded-xl p-4 border border-slate-200 shadow-sm transition-all duration-200 column-container" id="col-arbeit">
                <div class="flex items-center justify-between border-b-2 border-blue-500 pb-2 mb-4">
                    <span class="font-bold text-slate-700 flex items-center gap-1.5 text-sm uppercase tracking-wide">
                        <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span> In Arbeit
                    </span>
                    <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-0.5 rounded-full" id="zaehler-arbeit">0</span>
                </div>
                <div class="karten-liste space-y-3 min-h-[400px] transition-all rounded-lg" id="liste-arbeit"
                     ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)" ondrop="drop(event, 'arbeit')">
                </div>
            </div>

            <!-- Spalte: Im Test -->
            <div class="bg-slate-100 rounded-xl p-4 border border-slate-200 shadow-sm transition-all duration-200 column-container" id="col-test">
                <div class="flex items-center justify-between border-b-2 border-amber-500 pb-2 mb-4">
                    <span class="font-bold text-slate-700 flex items-center gap-1.5 text-sm uppercase tracking-wide">
                        <span class="w-2.5 h-2.5 rounded-full bg-amber-500"></span> Im Test
                    </span>
                    <span class="bg-amber-100 text-amber-700 text-xs font-bold px-2 py-0.5 rounded-full" id="zaehler-test">0</span>
                </div>
                <div class="karten-liste space-y-3 min-h-[400px] transition-all rounded-lg" id="liste-test"
                     ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)" ondrop="drop(event, 'test')">
                </div>
            </div>

            <!-- Spalte: Fertig -->
            <div class="bg-slate-100 rounded-xl p-4 border border-slate-200 shadow-sm transition-all duration-200 column-container" id="col-fertig">
                <div class="flex items-center justify-between border-b-2 border-emerald-500 pb-2 mb-4">
                    <span class="font-bold text-slate-700 flex items-center gap-1.5 text-sm uppercase tracking-wide">
                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span> Fertig
                    </span>
                    <span class="bg-emerald-100 text-emerald-700 text-xs font-bold px-2 py-0.5 rounded-full" id="zaehler-fertig">0</span>
                </div>
                <div class="karten-liste space-y-3 min-h-[400px] transition-all rounded-lg" id="liste-fertig"
                     ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)" ondrop="drop(event, 'fertig')">
                </div>
            </div>

        </div>
    </main>

    <!-- Sidebar Drawer für den Aktivitätsverlauf -->
    <div id="verlaufDrawer" class="fixed inset-y-0 right-0 w-full sm:w-96 bg-white border-l border-slate-200 shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
        <div class="p-4 border-b border-slate-200 flex items-center justify-between bg-slate-50">
            <div class="flex items-center gap-2 text-slate-800">
                <i data-lucide="history" class="w-5 h-5 text-blue-600"></i>
                <h3 class="font-bold text-sm uppercase tracking-wider">Aktivitätsverlauf</h3>
            </div>
            <button onclick="toggleVerlauf()" class="p-1.5 hover:bg-slate-200 rounded-lg text-slate-500 hover:text-slate-800 transition-all">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4 space-y-4" id="verlaufListe">
            <!-- Log-Einträge werden hier dynamisch gerendert -->
        </div>
        <div class="p-4 border-t border-slate-200 bg-slate-50 flex justify-between gap-3">
            <span class="text-xs text-slate-400 self-center" id="verlaufZaehler">0 Einträge</span>
            <button onclick="leereVerlauf()" class="px-3 py-1.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg text-xs font-semibold border border-red-100 transition-colors flex items-center gap-1">
                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Verlauf leeren
            </button>
        </div>
    </div>

    <!-- Einfaches modales Bestätigungsfenster zum Löschen -->
    <div id="deleteModal" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center z-50 hidden">
        <div class="bg-white p-6 rounded-xl border border-slate-200 max-w-sm w-full mx-4 shadow-xl">
            <div class="flex items-center gap-3 text-red-600 mb-3">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
                <h3 class="text-lg font-bold text-slate-950">Projekt löschen?</h3>
            </div>
            <p class="text-sm text-slate-500 mb-6">Möchtest du dieses Projekt wirklich unwiderruflich aus der Pipeline löschen?</p>
            <div class="flex justify-end gap-3">
                <button onclick="schließeDeleteModal()" class="px-4 py-2 border border-slate-200 text-slate-600 rounded-lg text-sm font-semibold hover:bg-slate-50">Abbrechen</button>
                <button id="confirmDeleteBtn" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-semibold shadow-sm">Ja, löschen</button>
            </div>
        </div>
    </div>

    <!-- Firebase v11 Module Script (MANDATORY setup) -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, collection, query, onSnapshot, addDoc, updateDoc, deleteDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Globales App State Management
        let db, auth;
        let appId = 'default-app-id';
        let currentUser = null;
        let projekte = [];
        let logs = [];
        let suchFilter = "";
        let deleteCandidateId = null;
        let hasLoadedOnce = false;

        // Firebase Initialisierung
        const firebaseConfig = JSON.parse(__firebase_config);
        appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

        const app = initializeApp(firebaseConfig);
        auth = getAuth(app);
        db = getFirestore(app);

        // REGEL 3: Authentifizierung zuerst durchführen
        async function initAuth() {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            } catch (e) {
                console.error("Authentifizierungsfehler:", e);
            }
        }

        // Auth Listener & Datenverbindung starten
        onAuthStateChanged(auth, (user) => {
            currentUser = user;
            if (user) {
                setupRealtimeSync();
            } else {
                console.warn("Benutzer nicht eingeloggt.");
            }
        });

        initAuth();

        // Echtzeit-Synchronisation mit der Cloud (REGEL 1 & 2 beachten)
        function setupRealtimeSync() {
            if (!currentUser) return;

            // Pfade exakt nach REGEL 1
            const projekteCol = collection(db, 'artifacts', appId, 'public', 'data', 'projekte');
            const logsCol = collection(db, 'artifacts', appId, 'public', 'data', 'logs');

            // 1. Synchronisation der Projekte
            onSnapshot(projekteCol, (snapshot) => {
                let tempProjekte = [];
                snapshot.forEach(doc => {
                    tempProjekte.push({ id: doc.id, ...doc.data() });
                });

                // Prepopulieren mit Beispieldaten, wenn die DB beim allerersten Start komplett leer ist
                if (tempProjekte.length === 0 && !hasLoadedOnce) {
                    hasLoadedOnce = true;
                    const defaultProjekte = [
                        { titel: "Einführung DMS-System", beschreibung: "Anforderungskatalog für digitales Dokumentenmanagement erstellen.", kategorie: "Organisation", prio: "prio-mittel", status: "neu", ref: 204, mitarbeiter: "Max Mustermann", deadline: "2026-07-15" },
                        { titel: "Hardware-Refresh Raum Z02", beschreibung: "Austausch der alten Client-PCs im Schulungsraum.", kategorie: "Infrastruktur", prio: "prio-niedrig", status: "neu", ref: 209, mitarbeiter: "Lisa Weber", deadline: "2026-06-25" }, // Überfällig (2026-06-29)
                        { titel: "Recruiting-Landingpage", beschreibung: "Prototyp für das Bewerberportal aufbauen und Formular validieren.", kategorie: "Digital", prio: "prio-hoch", status: "arbeit", ref: 185, mitarbeiter: "Jan Schmidt", deadline: "2026-07-05" },
                        { titel: "Schnittstelle Zeus-Software", beschreibung: "Testen der automatischen Datenübergabe für das neue Zeiterfassungsmodell.", kategorie: "Schnittstelle", prio: "prio-mittel", status: "test", ref: 172, mitarbeiter: "Sarah König", deadline: "2026-08-01" },
                        { titel: "Intranet WM-Tippspiel", beschreibung: "Veröffentlichung der interaktiven Tabellen und des Dashboards für die Kollegen.", kategorie: "Event", prio: "prio-niedrig", status: "fertig", ref: 199, mitarbeiter: "Ben Schuster", deadline: "2026-06-20" }
                    ];
                    
                    defaultProjekte.forEach(async (p, idx) => {
                        const docId = `demo-${idx + 1}`;
                        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projekte', docId), p);
                    });
                    
                    logActivity("System initialisiert mit Beispieldaten.");
                    return;
                }

                hasLoadedOnce = true;
                projekte = tempProjekte;
                renderBoard();
            }, (error) => {
                console.error("Fehler beim Synchronisieren der Projekte:", error);
            });

            // 2. Synchronisation der Aktivitäts-Logs (REGEL 2: Sortierung im JavaScript-Speicher)
            onSnapshot(logsCol, (snapshot) => {
                let tempLogs = [];
                snapshot.forEach(doc => {
                    tempLogs.push({ id: doc.id, ...doc.data() });
                });
                
                // Im Speicher nach Zeitstempel absteigend sortieren
                tempLogs.sort((a, b) => b.timestamp - a.timestamp);
                logs = tempLogs;
                renderLogs();
            }, (error) => {
                console.error("Fehler beim Synchronisieren der Logs:", error);
            });
        }

        // --- HILFSFUNKTIONEN FÜR AKTIVITÄTEN ---

        async function logActivity(text) {
            if (!currentUser) return;
            try {
                const logsCol = collection(db, 'artifacts', appId, 'public', 'data', 'logs');
                await addDoc(logsCol, {
                    text: text,
                    timestamp: Date.now(),
                    user: currentUser.isAnonymous ? "Kollege (Anonym)" : (currentUser.email || "Kollege")
                });
                
                // Zeige neuen Aktivitätspunkt am Button an
                const drawer = document.getElementById('verlaufDrawer');
                if (drawer && drawer.classList.contains('translate-x-full')) {
                    const badge = document.getElementById('verlaufBadge');
                    if (badge) badge.classList.remove('hidden');
                }
            } catch (e) {
                console.error("Aktivitätsaufzeichnungsfehler:", e);
            }
        }

        // --- RENDER FUNKTIONEN ---

        function renderBoard() {
            const listen = {
                neu: document.getElementById('liste-neu'),
                arbeit: document.getElementById('liste-arbeit'),
                test: document.getElementById('liste-test'),
                fertig: document.getElementById('liste-fertig')
            };

            Object.values(listen).forEach(l => { if (l) l.innerHTML = ''; });

            const gefilterteProjekte = projekte.filter(p => {
                const queryStr = suchFilter.toLowerCase();
                const mitarbeiterStr = (p.mitarbeiter || "").toLowerCase();
                return p.titel.toLowerCase().includes(queryStr) || 
                       p.beschreibung.toLowerCase().includes(queryStr) || 
                       mitarbeiterStr.includes(queryStr) ||
                       p.kategorie.toLowerCase().includes(queryStr);
            });

            gefilterteProjekte.forEach(projekt => {
                const karte = erstelleKartenHTML(projekt);
                if (listen[projekt.status]) {
                    listen[projekt.status].appendChild(karte);
                }
            });

            aktualisiereStatistik();
            lucide.createIcons();
        }

        function erstelleKartenHTML(projekt) {
            const card = document.createElement('div');
            card.setAttribute('draggable', 'true');
            card.classList.add('bg-white', 'p-4', 'rounded-xl', 'shadow-sm', 'hover:shadow-md', 'transition-all', 'cursor-grab', 'active:cursor-grabbing', 'border-l-4', 'relative', 'group');
            card.id = `card-${projekt.id}`;

            card.addEventListener('dragstart', (e) => dragStart(e, projekt.id));
            card.addEventListener('dragend', dragEnd);

            if (projekt.prio === 'prio-hoch') card.classList.add('border-l-rose-500');
            else if (projekt.prio === 'prio-mittel') card.classList.add('border-l-amber-400');
            else card.classList.add('border-l-emerald-500');

            // Initialen & Hintergrundfarbe für Mitarbeiter bestimmen
            const mitarbeiterName = projekt.mitarbeiter || "Unzugewiesen";
            const initials = getInitials(mitarbeiterName);
            const avatarColor = getAvatarColor(mitarbeiterName);

            // Überfälligkeits-Check & Badge-Erstellung
            const deadlineBadgeHTML = getDeadlineBadge(projekt.deadline, projekt.status);

            card.innerHTML = `
                <!-- Buttons beim Hovern -->
                <div class="absolute top-3 right-3 flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button onclick="bearbeiteProjekt('${projekt.id}')" class="p-1 hover:bg-slate-100 rounded text-slate-500 hover:text-slate-800 transition-colors" title="Bearbeiten">
                        <i data-lucide="edit-2" class="w-3.5 h-3.5"></i>
                    </button>
                    <button onclick="frageLöschen('${projekt.id}')" class="p-1 hover:bg-rose-50 rounded text-slate-400 hover:text-red-600 transition-colors" title="Löschen">
                        <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                    </button>
                </div>

                <h3 class="font-bold text-slate-900 pr-12 text-sm leading-tight">${escapeHTML(projekt.titel)}</h3>
                <p class="text-slate-600 text-xs mt-1.5 line-clamp-3 leading-relaxed">${escapeHTML(projekt.beschreibung)}</p>
                
                <div class="mt-4 pt-3 border-t border-slate-100 flex items-center justify-between gap-2 flex-wrap">
                    <span class="bg-slate-100 text-slate-600 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">${escapeHTML(projekt.kategorie)}</span>
                    <span class="text-[10px] text-slate-400 font-semibold">Ref: #${projekt.ref}</span>
                </div>

                <!-- Neue Statuszeile: Deadline & Mitarbeiter-Avatar -->
                <div class="mt-3 pt-3 border-t border-slate-50 flex items-center justify-between gap-2">
                    <div class="flex items-center gap-1.5">
                        ${deadlineBadgeHTML}
                    </div>
                    
                    <!-- Avatar mit Tooltip -->
                    <div class="${avatarColor} w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold border shadow-sm cursor-help relative" title="${escapeHTML(mitarbeiterName)}">
                        ${escapeHTML(initials)}
                    </div>
                </div>

                <!-- Touch & Mobil-Dropdown -->
                <div class="mt-3 block md:hidden pt-2 border-t border-slate-50 flex items-center gap-1 justify-end">
                    <label class="text-[10px] font-medium text-slate-400">Status:</label>
                    <select onchange="verschiebeManuell('${projekt.id}', this.value)" class="text-[10px] bg-slate-50 border border-slate-200 rounded px-1.5 py-0.5 text-slate-600 font-semibold focus:outline-none">
                        <option value="neu" ${projekt.status === 'neu' ? 'selected' : ''}>Neu</option>
                        <option value="arbeit" ${projekt.status === 'arbeit' ? 'selected' : ''}>In Arbeit</option>
                        <option value="test" ${projekt.status === 'test' ? 'selected' : ''}>Im Test</option>
                        <option value="fertig" ${projekt.status === 'fertig' ? 'selected' : ''}>Fertig</option>
                    </select>
                </div>
            `;
            return card;
        }

        // Render-Logik für die Logs
        function renderLogs() {
            const listContainer = document.getElementById('verlaufListe');
            const countContainer = document.getElementById('verlaufZaehler');
            if (!listContainer) return;

            listContainer.innerHTML = '';
            countContainer.innerText = `${logs.length} Einträge`;

            if (logs.length === 0) {
                listContainer.innerHTML = `
                    <div class="text-center py-12 text-slate-400 text-sm">
                        <i data-lucide="info" class="w-8 h-8 mx-auto mb-2 opacity-50"></i>
                        Noch keine Aktivitäten aufgezeichnet.
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            logs.forEach(log => {
                const timeStr = formatLogTime(log.timestamp);
                const entry = document.createElement('div');
                entry.className = 'border-b border-slate-100 pb-3 text-xs';
                entry.innerHTML = `
                    <div class="flex justify-between text-[10px] text-slate-400 font-semibold mb-1">
                        <span>${escapeHTML(log.user || 'Anonymer Kollege')}</span>
                        <span>${timeStr}</span>
                    </div>
                    <p class="text-slate-600 leading-relaxed">${escapeHTML(log.text)}</p>
                `;
                listContainer.appendChild(entry);
            });

            lucide.createIcons();
        }

        // --- STATISTIKEN & FORMATIERUNGEN ---

        function aktualisiereStatistik() {
            const counts = { neu: 0, arbeit: 0, test: 0, fertig: 0 };
            projekte.forEach(p => {
                if (counts[p.status] !== undefined) counts[p.status]++;
            });

            const neuEl = document.getElementById('zaehler-neu');
            const arbeitEl = document.getElementById('zaehler-arbeit');
            const testEl = document.getElementById('zaehler-test');
            const fertigEl = document.getElementById('zaehler-fertig');

            if (neuEl) neuEl.innerText = counts.neu;
            if (arbeitEl) arbeitEl.innerText = counts.arbeit;
            if (testEl) testEl.innerText = counts.test;
            if (fertigEl) fertigEl.innerText = counts.fertig;

            // Header-Statistik
            const gesamtEl = document.getElementById('stat-gesamt');
            const statArbeitEl = document.getElementById('stat-arbeit');
            const statTestEl = document.getElementById('stat-test');
            const statFertigEl = document.getElementById('stat-fertig');

            if (gesamtEl) gesamtEl.innerText = projekte.length;
            if (statArbeitEl) statArbeitEl.innerText = counts.arbeit;
            if (statTestEl) statTestEl.innerText = counts.test;
            if (statFertigEl) statFertigEl.innerText = counts.fertig;
        }

        function getDeadlineBadge(deadline, status) {
            if (!deadline) {
                return `
                    <span class="inline-flex items-center gap-1 text-slate-400 text-[10px] font-medium">
                        Keine Deadline
                    </span>
                `;
            }

            const today = new Date();
            today.setHours(0,0,0,0);
            const dl = new Date(deadline);
            const dateStr = formatDate(deadline);

            if (status !== 'fertig' && dl < today) {
                // Überfällig
                return `
                    <span class="inline-flex items-center gap-1 bg-red-50 text-red-600 text-[10px] font-bold px-2 py-0.5 rounded border border-red-100" title="Deadline am ${dateStr} war überschritten!">
                        <i data-lucide="alert-circle" class="w-3 h-3"></i> Überfällig
                    </span>
                `;
            } else if (status === 'fertig') {
                return `
                    <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-600 text-[10px] font-medium px-2 py-0.5 rounded border border-emerald-100" title="Projekt pünktlich abgeschlossen.">
                        <i data-lucide="check" class="w-3 h-3"></i> Erledigt
                    </span>
                `;
            } else {
                return `
                    <span class="inline-flex items-center gap-1 bg-slate-50 text-slate-500 text-[10px] font-semibold px-2 py-0.5 rounded border border-slate-100" title="Soll fertiggestellt sein bis: ${dateStr}">
                        <i data-lucide="calendar" class="w-3 h-3 text-slate-400"></i> ${dateStr}
                    </span>
                `;
            }
        }

        function getInitials(name) {
            if (!name) return "??";
            const parts = name.trim().split(/\s+/);
            if (parts.length === 1) return parts[0].substring(0, 2).toUpperCase();
            return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
        }

        function getAvatarColor(name) {
            const colors = [
                'bg-pink-100 text-pink-700 border-pink-200',
                'bg-purple-100 text-purple-700 border-purple-200',
                'bg-blue-100 text-blue-700 border-blue-200',
                'bg-amber-100 text-amber-700 border-amber-200',
                'bg-emerald-100 text-emerald-700 border-emerald-200',
                'bg-teal-100 text-teal-700 border-teal-200',
                'bg-indigo-100 text-indigo-700 border-indigo-200',
            ];
            let sum = 0;
            for (let i = 0; i < name.length; i++) {
                sum += name.charCodeAt(i);
            }
            return colors[sum % colors.length];
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            const parts = dateStr.split('-');
            if (parts.length === 3) {
                return `${parts[2]}.${parts[1]}.${parts[0]}`;
            }
            return dateStr;
        }

        function formatLogTime(timestamp) {
            if (!timestamp) return '';
            const d = new Date(timestamp);
            const options = { hour: '2-digit', minute: '2-digit' };
            const time = d.toLocaleTimeString('de-DE', options);
            const date = d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' });
            return `${time} Uhr (${date})`;
        }

        function getNextRef() {
            if (projekte.length === 0) return 210;
            const refs = projekte.map(p => Number(p.ref) || 0);
            return Math.max(...refs) + 1;
        }

        // --- INTERAKTIVE DRAG & DROP EVENT-HANDLER ---

        function dragStart(e, id) {
            e.dataTransfer.setData('text/plain', id);
            setTimeout(() => {
                const target = document.getElementById(`card-${id}`);
                if (target) target.classList.add('opacity-40');
            }, 0);
        }

        function dragEnd(e) {
            e.target.classList.remove('opacity-40');
            document.querySelectorAll('.column-container').forEach(c => {
                c.classList.remove('bg-blue-50/70', 'border-blue-300', 'scale-[1.01]');
            });
        }

        function allowDrop(e) {
            e.preventDefault();
        }

        function dragEnter(e) {
            e.preventDefault();
            const col = e.target.closest('.column-container');
            if (col) {
                col.classList.add('bg-blue-50/70', 'border-blue-300', 'scale-[1.01]');
            }
        }

        function dragLeave(e) {
            const col = e.target.closest('.column-container');
            if (col && !col.contains(e.relatedTarget)) {
                col.classList.remove('bg-blue-50/70', 'border-blue-300', 'scale-[1.01]');
            }
        }

        async function drop(e, zielStatus) {
            e.preventDefault();
            const id = e.dataTransfer.getData('text/plain');
            const projekt = projekte.find(p => p.id === id);

            if (projekt && projekt.status !== zielStatus) {
                const alterStatus = projekt.status;
                
                // Firestore Update
                try {
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'projekte', id);
                    await updateDoc(docRef, { status: zielStatus });
                    
                    const statusMap = { neu: 'Neu', arbeit: 'In Arbeit', test: 'Im Test', fertig: 'Fertig' };
                    await logActivity(`"${projekt.titel}" wurde von "${statusMap[alterStatus]}" nach "${statusMap[zielStatus]}" verschoben.`);
                } catch (err) {
                    console.error("Verschiebe-Fehler:", err);
                }
            }
        }

        async function verschiebeManuell(id, zielStatus) {
            const projekt = projekte.find(p => p.id === id);
            if (projekt && projekt.status !== zielStatus) {
                const alterStatus = projekt.status;
                try {
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'projekte', id);
                    await updateDoc(docRef, { status: zielStatus });
                    
                    const statusMap = { neu: 'Neu', arbeit: 'In Arbeit', test: 'Im Test', fertig: 'Fertig' };
                    await logActivity(`"${projekt.titel}" manuell nach "${statusMap[zielStatus]}" verschoben.`);
                } catch (err) {
                    console.error("Verschiebe-Fehler:", err);
                }
            }
        }

        // --- CRUD BEDIENUNG ---

        document.getElementById('projektForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const editId = document.getElementById('editId').value;
            const titel = document.getElementById('titel').value;
            const beschreibung = document.getElementById('beschreibung').value;
            const mitarbeiter = document.getElementById('mitarbeiter').value;
            const deadline = document.getElementById('deadline').value;
            const kategorie = document.getElementById('kategorie').value;
            const prio = document.getElementById('prio').value;

            try {
                if (editId) {
                    // Aktualisieren
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'projekte', editId);
                    await updateDoc(docRef, {
                        titel,
                        beschreibung,
                        mitarbeiter,
                        deadline,
                        kategorie,
                        prio
                    });
                    await logActivity(`Projekt "${titel}" wurde erfolgreich bearbeitet.`);
                } else {
                    // Neues erstellen
                    const refNum = getNextRef();
                    const neues = {
                        titel,
                        beschreibung,
                        mitarbeiter,
                        deadline,
                        kategorie,
                        prio,
                        status: 'neu',
                        ref: refNum
                    };
                    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'projekte'), neues);
                    await logActivity(`Neues Projekt "${titel}" (#${refNum}) wurde von ${mitarbeiter} erstellt.`);
                }

                setzeFormularZurueck();
            } catch (err) {
                console.error("Fehler beim Speichern:", err);
            }
        });

        function bearbeiteProjekt(id) {
            const projekt = projekte.find(p => p.id === id);
            if (!projekt) return;

            document.getElementById('editId').value = projekt.id;
            document.getElementById('titel').value = projekt.titel;
            document.getElementById('beschreibung').value = projekt.beschreibung;
            document.getElementById('mitarbeiter').value = projekt.mitarbeiter || "";
            document.getElementById('deadline').value = projekt.deadline || "";
            document.getElementById('kategorie').value = projekt.kategorie;
            document.getElementById('prio').value = projekt.prio;

            document.getElementById('formularTitel').innerText = "Projekt bearbeiten";
            document.getElementById('btnText').innerText = "Speichern";
            document.getElementById('btnAbbrechen').classList.remove('hidden');

            document.querySelector('.form-container')?.scrollIntoView({ behavior: 'smooth' });
        }

        function setzeFormularZurueck() {
            document.getElementById('projektForm').reset();
            document.getElementById('editId').value = "";
            document.getElementById('formularTitel').innerText = "Neues IT-Projekt erfassen";
            document.getElementById('btnText').innerText = "Anlegen";
            document.getElementById('btnAbbrechen').classList.add('hidden');
        }

        // --- DRAWER & MODALS ---

        function toggleVerlauf() {
            const drawer = document.getElementById('verlaufDrawer');
            if (drawer) {
                drawer.classList.toggle('translate-x-full');
            }
            // Badge bei Klick verstecken
            const badge = document.getElementById('verlaufBadge');
            if (badge) badge.classList.add('hidden');
        }

        async function leereVerlauf() {
            if (!currentUser) return;
            try {
                // Alle aktuellen logs einzeln löschen (REGEL 2 beachten: keine komplexen Batch-Queries ohne Index)
                for (const log of logs) {
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'logs', log.id);
                    await deleteDoc(docRef);
                }
                await logActivity("Aktivitätsverlauf wurde bereinigt.");
            } catch (e) {
                console.error("Fehler beim Löschen des Verlaufs:", e);
            }
        }

        function frageLöschen(id) {
            deleteCandidateId = id;
            const modal = document.getElementById('deleteModal');
            if (modal) modal.classList.remove('hidden');
        }

        function schließeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            if (modal) modal.classList.add('hidden');
            deleteCandidateId = null;
        }

        document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
            if (deleteCandidateId !== null) {
                const projekt = projekte.find(p => p.id === deleteCandidateId);
                const name = projekt ? projekt.titel : deleteCandidateId;
                
                try {
                    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'projekte', deleteCandidateId);
                    await deleteDoc(docRef);
                    await logActivity(`Projekt "${name}" wurde unwiderruflich gelöscht.`);
                } catch (e) {
                    console.error("Fehler beim Löschen:", e);
                }
                schließeDeleteModal();
            }
        });

        function filterProjekte() {
            const sucheInput = document.getElementById('suche');
            if (sucheInput) {
                suchFilter = sucheInput.value;
                renderBoard();
            }
        }

        function escapeHTML(str) {
            if (!str) return "";
            return str.replace(/[&<>'"]/g, 
                tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
            );
        }

        // Module-Methoden im globalen Window-Objekt registrieren, damit HTML-Events sie erreichen
        window.toggleVerlauf = toggleVerlauf;
        window.leereVerlauf = leereVerlauf;
        window.allowDrop = allowDrop;
        window.dragEnter = dragEnter;
        window.dragLeave = dragLeave;
        window.drop = drop;
        window.verschiebeManuell = verschiebeManuell;
        window.bearbeiteProjekt = bearbeiteProjekt;
        window.frageLöschen = frageLöschen;
        window.schließeDeleteModal = schließeDeleteModal;
        window.setzeFormularZurueck = setzeFormularZurueck;
        window.filterProjekte = filterProjekte;
    </script>
</body>
</html>
